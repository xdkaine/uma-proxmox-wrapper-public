# Security Hardening
RATE_LIMIT_TRUST_PROXY=false
PROXMOX_SSL_INSECURE=false

# Proxmox Configuration
# The URL of your Proxmox API (e.g., https://192.168.1.10:8006).
PROXMOX_URL=https://your-proxmox-host:8006

# API Token for the service account.
# Create this in Proxmox under Datacenter > Permissions > API Tokens.
# Uncheck "Privilege Separation" if you want the token to have the full rights of the user.
PROXMOX_TOKEN_ID=root@pam!proxmox-wrapper
PROXMOX_TOKEN_SECRET=your-uuid-token-secret

# Proxmox User Realm
# Default realm to append to usernames when creating ACLs (e.g., 'SDC', 'pam', 'pve')
# This should match your LDAP/AD domain configured in Proxmox
PROXMOX_USER_REALM=SDC

# SSL Verification (HIGH-3: Use per-request control instead of global)
# For self-signed Proxmox certificates, use PROXMOX_SSL_INSECURE=true (not recommended for production)
# For production, install proper CA certificates or add Proxmox cert to trusted store
PROXMOX_SSL_INSECURE=false

# LDAP Configuration (for User Login)
# The URL of your LDAP/Active Directory server.
LDAP_URL=ldap://your-ldap-server:389

# Service account to search for users.
LDAP_BIND_DN=cn=service-account,dc=example,dc=com
LDAP_BIND_PASSWORD=service-account-password

# Base DN where users are located.
LDAP_BASE_DN=dc=example,dc=com

# Filter to find the user by username. {{username}} is replaced by the input.
# For Active Directory, use: (sAMAccountName={{username}})
# For OpenLDAP, use: (uid={{username}})
LDAP_USER_SEARCH_FILTER=(sAMAccountName={{username}})

# LDAP attributes to use for user search
# Comma-separated list of attributes for username lookup
# For AD: sAMAccountName,cn
# For OpenLDAP: uid,cn
LDAP_SEARCH_ATTRIBUTES=sAMAccountName,cn

# Session Security
# A strong random string (at least 32 chars) to encrypt session cookies.
# Generate with: node scripts/generate-secrets.js
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_COOKIE_PASSWORD=your-secure-random-secret-at-least-32-characters-long

# Session TTL (Time To Live) in seconds
# Default: 28800 (8 hours)
# Set to 0 to disable expiration (NOT RECOMMENDED for production - security risk)
# Minimum recommended for production: 3600 (1 hour)
SESSION_TTL=28800

# Admin Groups
# Comma separated list of groups that are considered admins
ADMIN_GROUPS="Domain Admins,Administrator"

# Database
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_DATABASE=proxmox_wrapper
MYSQL_USER=proxmox
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL="mysql://proxmox:CHANGE_ME_STRONG_PASSWORD@localhost:3306/proxmox_wrapper"
